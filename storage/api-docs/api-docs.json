                                                "nama": {
                                                    "type": "string",
                                                    "example": "Mousepad Gaming XL"
                                                },
                                                "harga": {
                                                    "type": "number",
                                                    "example": 150000
                                                },
                                                "stok": {
                                                    "type": "integer",
                                                    "example": 50
                                                },
                                                "kategori": {
                                                    "type": "string",
                                                    "example": "Aksesoris"
                                                },
                                                "deskripsi": {
                                                    "type": "string",
                                                    "example": "Mousepad gaming ukuran XL anti-slip"
