                                                    "nama": {
                                                        "type": "string",
                                                        "example": "Laptop ASUS ROG Strix"
                                                    },
                                                    "harga": {
                                                        "type": "number",
                                                        "example": 18500000
                                                    },
                                                    "stok": {
                                                        "type": "integer",
                                                        "example": 12
                                                    },
                                                    "kategori": {
                                                        "type": "string",
                                                        "example": "Elektronik"
                                                    },
                                                    "deskripsi": {
                                                        "type": "string",
                                                        "example": "Laptop gaming high-end dengan RTX 4060"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        },
                                        "total": {
                                            "type": "integer",
                                            "example": 8
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
