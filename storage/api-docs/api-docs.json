                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nama",
                                    "harga"
                                ],
                                "properties": {
                                    "nama": {
                                        "description": "Nama barang (wajib)",
                                        "type": "string",
                                        "example": "Mousepad Gaming XL"
                                    },
                                    "harga": {
                                        "description": "Harga barang dalam Rupiah (wajib)",
                                        "type": "number",
                                        "example": 150000
                                    },
                                    "stok": {
                                        "description": "Jumlah stok (opsional, default: 0)",
                                        "type": "integer",
                                        "example": 50
                                    },
                                    "kategori": {
                                        "description": "Kategori barang (opsional)",
                                        "type": "string",
                                        "example": "Aksesoris"
                                    },
                                    "deskripsi": {
                                        "description": "Deskripsi barang (opsional)",
                                        "type": "string",
                                        "example": "Mousepad gaming ukuran XL anti-slip"
