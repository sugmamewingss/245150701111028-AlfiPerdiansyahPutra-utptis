                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validasi gagal",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "error"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Validasi gagal"
                                        },
                                        "errors": {
                                            "type": "object",
                                            "example": "{\"nama\": [\"Nama barang wajib diisi\"]}"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
